        <mxCell id="r8c1" value="License" style="text;html=1;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="720" y="504" width="120" height="22" as="geometry"/></mxCell>
        <mxCell id="r8c2" value="Apache 2.0" style="text;html=1;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="840" y="504" width="120" height="22" as="geometry"/></mxCell>
        <mxCell id="r8c3" value="BSL (limited)" style="text;html=1;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="960" y="504" width="120" height="22" as="geometry"/></mxCell>
        <mxCell id="r8c4" value="Apache 2.0" style="text;html=1;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1080" y="504" width="130" height="22" as="geometry"/></mxCell>
        <mxCell id="r8c5" value="&lt;b&gt;Apache 2.0&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1210" y="504" width="150" height="22" as="geometry"/></mxCell>

        <!-- Bangalore ICP on the right -->
        <mxCell id="blr-title" value="&lt;b&gt;BANGALORE ICP TARGETS (from Playbook)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="720" y="540" width="640" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="blr1" value="&lt;b&gt;GCC — Mid-Market (200–2,000 eng)&lt;/b&gt;  ★★★★★  Reach: Medium&lt;br&gt;Walmart IQ, Atlassian, Zynga, Gojek R&amp;D&lt;br&gt;Buyer: Staff SDE + EM → VP Eng | Pitch: io_uring P99 improvement" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="570" width="640" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="blr2" value="&lt;b&gt;GCC — Emerging ($10M+, 50–300 eng)&lt;/b&gt;  ★★★★★  Reach: Low-Med&lt;br&gt;Sweet spot: big enough for real pain, small enough for individual influence&lt;br&gt;Buyer: SDE III + EM → CTO | Pitch: single binary = zero ops overhead" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="630" width="640" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="blr3" value="&lt;b&gt;Public Market Tech (India-listed)&lt;/b&gt;  ★★★★☆  Reach: Med-High&lt;br&gt;Razorpay, Zerodha, Zomato, Swiggy | Latency = revenue in payments/trading&lt;br&gt;Buyer: Platform Eng Lead → VP Eng | Pitch: JVM GC = P99 spikes in financial events" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="690" width="640" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="blr4" value="&lt;b&gt;PE-Backed Scale-ups&lt;/b&gt;  ★★★★☆  Reach: Low-Med&lt;br&gt;D2C tech, logistics, BFSI fintech | Infrastructure modernization mandate&lt;br&gt;Buyer: SDE + EM → CTO | Pitch: no ZooKeeper, no Schema Registry, no JVM" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="750" width="640" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="blr5" value="&lt;b&gt;Rust Greenfield Builders&lt;/b&gt;  ★★★★★  Reach: Very Low&lt;br&gt;OSS contributors, startups, solo engineers | Crates.io = distribution channel&lt;br&gt;Buyer = user | Pitch: only native Rust persistent streaming platform" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="810" width="640" height="55" as="geometry"/>
        </mxCell>

        <!-- BTD Legend -->
        <mxCell id="btd-legend" value="&lt;b&gt;BTD FRAMEWORK LEGEND (Shreyas Doshi)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#2d7d46;&amp;quot;&gt;🟢 DIFFERENTIATING:&lt;/b&gt; The thing you do uniquely well that makes users pick you.&lt;br&gt;If you're not #1 here, you have no right to win.&lt;br&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#b85450;&amp;quot;&gt;🔴 AT TABLE STAKES:&lt;/b&gt; You must be good enough. Not a competitive advantage.&lt;br&gt;Being amazing here doesn't help; being bad here kills you.&lt;br&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#999;&amp;quot;&gt;⚪ BELOW TABLE STAKES:&lt;/b&gt; Don't invest here. Users don't care,&lt;br&gt;and investing here distracts from Differentiating." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#666666;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="880" width="640" height="190" as="geometry"/>
        </mxCell>

        <!-- Enduring Thesis -->
        <mxCell id="thesis" value="&lt;b&gt;THE ENDURING THESIS&lt;/b&gt;&lt;br&gt;Iggy wins not by being the best at what Kafka does, but by being the only credible answer to a different question:&lt;br&gt;&amp;quot;What do I use when I want the absolute hardware maximum, I'm building in Rust, and I refuse to inherit a decade of JVM debt?&amp;quot;&lt;br&gt;In 3 years, every Rust engineer considering event streaming should default to asking &amp;quot;Is Apache Iggy the right tool?&amp;quot;&lt;br&gt;before &amp;quot;Which flavor of Kafka should I use?&amp;quot; That mental model shift = the entire GTM." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;spacingTop=8;spacingBottom=8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="1085" width="640" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page3-bets" name="Bets-Execution">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="btitle" value="&lt;b&gt;SEQUENCE OF BETS (Shreyas Doshi: Hierarchy of Moves)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="100" y="15" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- BET 1 -->
        <mxCell id="b1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1320" height="270" as="geometry"/>
        </mxCell>
        <mxCell id="b1-header" value="&lt;b&gt;BET 1 (Now — 0–6 months): OWN THE RUST DEVELOPER'S STREAMING CONVERSATION&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=13;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1320" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="b1-body" value="The Rust ecosystem has NO incumbent for persistent streaming. Iggy should be synonymous with streaming&lt;br&gt;in Rust before any other motion. This is a &lt;b&gt;category creation play&lt;/b&gt;, not a comparison play.&lt;br&gt;&lt;br&gt;&lt;b&gt;Concrete Actions:&lt;/b&gt;&lt;br&gt;• Write an Iggy quick-start guide for awesome-rust repository&lt;br&gt;• Submit &amp;quot;iggy&amp;quot; as recommended streaming crate in Rust ecosystem guide&lt;br&gt;• Publish weekly &amp;quot;What we shipped&amp;quot; post on Apache Iggy blog — dev velocity as marketing&lt;br&gt;• Bangalore: Rust India Meetup talk (2,700 members, monthly cadence, hosted at JUSPAY/Target/Gojek)&lt;br&gt;• Bangalore: Open Source India 2026 (Oct 7–8, NIMHANS) — submit Iggy + benchmark demo session&lt;br&gt;• Bangalore: JOSH (April) + OpenSource For You magazine + LinkedIn content (3x/week)&lt;br&gt;• &amp;quot;Tedious Arch&amp;quot; Podcast: GCC engineering leaders talk real architecture decisions — Iggy = solution, not pitch&lt;br&gt;• Parseltongue demo: &amp;quot;I use Iggy as the event bus in an LLM agent project I'm actively shipping&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="1320" height="235" as="geometry"/>
        </mxCell>

        <!-- BET 2 -->
        <mxCell id="b2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="1320" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="b2-header" value="&lt;b&gt;BET 2 (3–9 months): MAKE THE BENCHMARK DASHBOARD FAMOUS&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=13;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="1320" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="b2-body" value="benchmarks.iggy.apache.org is the &lt;b&gt;most underrated GTM asset in streaming&lt;/b&gt;. No competitor has a&lt;br&gt;community-driven, reproducible public benchmark dashboard. This directly attacks Redpanda/Confluent credibility.&lt;br&gt;&lt;br&gt;&lt;b&gt;Concrete Actions:&lt;/b&gt;&lt;br&gt;• Write &amp;quot;Why We Made Our Benchmarks Public&amp;quot; — values-based narrative for Hacker News&lt;br&gt;• Invite community to submit hardware results (different cloud instances, bare metal, India-specific configs)&lt;br&gt;• Create &amp;quot;Compare Your Kafka/NATS Setup&amp;quot; guide that leads engineers to the benchmark tool&lt;br&gt;• Bangalore: Submit India-specific benchmark results to benchmarks.iggy.apache.org&lt;br&gt;• GCC demo motion: Run iggy-bench against their Kafka config on equivalent hardware — present results" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="1320" height="195" as="geometry"/>
        </mxCell>

        <!-- BET 3 -->
        <mxCell id="b3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1320" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="b3-header" value="&lt;b&gt;BET 3 (6–18 months): BUILD THE &amp;quot;NO-KAFKA-REQUIRED&amp;quot; NARRATIVE&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=13;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1320" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="b3-body" value="As clustering (VSR-based) approaches completion, Iggy transitions from single-node to production-HA.&lt;br&gt;Launch &amp;quot;Go-to-Production with Iggy&amp;quot; campaign targeting platform teams and edge operators.&lt;br&gt;&lt;br&gt;&lt;b&gt;Concrete Actions:&lt;/b&gt;&lt;br&gt;• &amp;quot;You don't need Kafka if you're starting fresh&amp;quot; — the narrative backbone&lt;br&gt;• Starter templates: iggy-microservice-template, iggy-realtime-dashboard, iggy-ai-agent-event-bus&lt;br&gt;• &amp;quot;How to evaluate Apache Iggy in one sprint&amp;quot; — solution engineering guide&lt;br&gt;• Bangalore: Iggy India Adopters private channel — word-of-mouth flywheel&lt;br&gt;• Case studies from BLR GCC production deployments → iggy.apache.org/blogs" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d6b656;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="625" width="1320" height="165" as="geometry"/>
        </mxCell>

        <!-- 8-Week Sprint -->
        <mxCell id="sprint-title" value="&lt;b&gt;8-WEEK SPRINT PLAN (Amul's Bangalore Sabbatical: March–April 2026)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="805" width="1200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="w12" value="&lt;b&gt;Week 1–2: Foundation + Listening&lt;/b&gt;&lt;br&gt;• Map 100 BLR target orgs (GCC + PE) — spreadsheet: company, eng size, tech stack, leader&lt;br&gt;• Join: Rust India, JOSH, OSI 2026 Slack, Iggy Discord — genuine intro, not pitch&lt;br&gt;• Audit India content gap: top 5 unanswered Kafka questions on Reddit/LinkedIn&lt;br&gt;• Set up iggy-india GitHub discussion thread&lt;br&gt;• Write first LinkedIn post: &amp;quot;The hidden cost of Kafka in a 50-SDE team&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="840" width="650" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="w34" value="&lt;b&gt;Week 3–4: Content Launch&lt;/b&gt;&lt&gt;• Publish first HLD blog: &amp;quot;Messaging for Multi-Service Arch: What I Wish I Knew Before Picking Kafka&amp;quot;&lt;br&gt;• YouTube: &amp;quot;Apache Iggy in 10 Minutes: Hello Streaming&amp;quot;&lt;br&gt;• Submit Rust India meetup talk proposal&lt;br&gt;• Record Tedious Arch Ep 1: &amp;quot;Why Streaming Architecture Is Tedious&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="840" width="650" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="w56" value="&lt;b&gt;Week 5–6: Community Activation&lt;/b&gt;&lt;br&gt;• Deliver Rust India meetup talk — demo Iggy + Parseltongue&lt;br&gt;• Identify 10 GCCs from 100 list with recent Kafka/NATS job postings&lt;br&gt;• Outreach to 5 eng leaders: 30-min research conversation (non-salesy)&lt;br&gt;• Publish iggy-microservice-template on GitHub" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="965" width="650" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="w78" value="&lt;b&gt;Week 7–8: First POCs + Feedback&lt;/b&gt;&lt;br&gt;• Run 2–3 Custom Demo / Architecture Review sessions&lt;br&gt;• Publish: &amp;quot;What Indian Eng Teams Actually Need From Streaming&amp;quot;&lt;br&gt;• Submit OSI 2026 talk proposal&lt;br&gt;• Record Tedious Arch Ep 2: first GCC platform eng guest" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="965" width="650" height="100" as="geometry"/>
        </mxCell>

        <!-- Metrics -->
        <mxCell id="m8w" value="&lt;b&gt;8-WEEK MILESTONES&lt;/b&gt;  (by end of April 2026)&lt;br&gt;• 1 meetup talk delivered&lt;br&gt;• 4 HLD blog posts (&amp;gt;500 impressions each)&lt;br&gt;• 2 podcast episodes published&lt;br&gt;• 3 starter templates on GitHub&lt;br&gt;• 10 discovery conversations logged&lt;br&gt;• 3 POC sessions conducted&lt;br&gt;• 1 India benchmark on iggy.apache.org" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1075" width="420" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="m6m" value="&lt;b&gt;6-MONTH MILESTONES&lt;/b&gt;  (by end of September 2026)&lt;br&gt;• 1 confirmed production pilot at BLR GCC or PE co&lt;br&gt;• 1 Indian engineer's first Iggy contribution&lt;br&gt;• Accepted talk at OSI 2026 (October)&lt;br&gt;• 10+ podcast episodes with BLR eng leaders&lt;br&gt;• Measurable IST-timezone activity on Discord&lt;br&gt;• &amp;quot;Iggy India&amp;quot; page live on official docs&lt;br&gt;• Cited in 1+ Indian tech publication" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1075" width="420" height="130" as="geometry"/>
        </mxCell>

        <!-- War of Art -->
        <mxCell id="woa" value="&lt;b&gt;&amp;quot;THE WAR OF ART&amp;quot; PRINCIPLE&lt;/b&gt;&lt;br&gt;&lt;br&gt;The risk is not strategy — it's Resistance: the pull to research&lt;br&gt;instead of write, plan instead of build, wait for the perfect&lt;br&gt;talk instead of the imperfect one.&lt;br&gt;&lt;br&gt;&lt;b&gt;Ship imperfect content immediately.&lt;/b&gt; The flywheel starts&lt;br&gt;turning only when you are &lt;b&gt;visible&lt;/b&gt;, not when you are ready.&lt;br&gt;&lt;br&gt;Apply the 90% filter ruthlessly: only write where Iggy&lt;br&gt;is the clear best answer, only pitch where messaging&lt;br&gt;infrastructure is &lt;b&gt;active pain&lt;/b&gt;." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;spacingTop=8;spacingBottom=8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="1075" width="440" height="130" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page4-funnel" name="Funnel-Touchpoints">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1050">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="ftitle" value="&lt;b&gt;USER JOURNEY × TOUCH-POINT MAP&lt;/b&gt;&lt;br&gt;Awareness → Curiosity → Evaluation → Adoption → Advocacy (The J-Curve)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="15" width="1200" height="45" as="geometry"/>
        </mxCell>

        <!-- Stage 0: Awareness -->
        <mxCell id="s0" value="&lt;b&gt;STAGE 0: AWARENESS (Broadcast)&lt;/b&gt;&lt;br&gt;&lt;b&gt;Goal:&lt;/b&gt; Amul = recognizable face of &amp;quot;Rust-native streaming in India&amp;quot;&lt;br&gt;&lt;br&gt;• Rust India BLR Meetup — &amp;quot;Building Real-Time [X] with Apache Iggy&amp;quot; (monthly, at JUSPAY/Target/Gojek)&lt;br&gt;• Open Source India 2026 (Oct 7–8, NIMHANS) — Iggy + benchmark dashboard demo&lt;br&gt;• OpenSource For You magazine + opensourceindia.in — India's leading OSS pub&lt;br&gt;• JOSH (Just an Open Source Hub) April Bangalore events&lt;br&gt;• LinkedIn: 2–3 posts/week on Rust + streaming infra + Indian eng challenges" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1320" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="arr01" value="" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="210" as="sourcePoint"/>
            <mxPoint x="700" y="225" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 1: Curiosity -->
        <mxCell id="s1" value="&lt;b&gt;STAGE 1: CURIOSITY (Content-Led Education)&lt;/b&gt;&lt;br&gt;&lt;b&gt;Goal:&lt;/b&gt; Engineer who saw Amul's name now spends 10 min reading/watching something specific&lt;br&gt;&lt;br&gt;&lt;b&gt;Tier 1 — Quick Wins (CRUD, widest reach):&lt;/b&gt; &amp;quot;5 Signs Your Kafka Setup Costs Too Much&amp;quot; | &amp;quot;What is io_uring?&amp;quot; | &amp;quot;Iggy in 5 Minutes&amp;quot; screencast&lt;br&gt;&lt;b&gt;Tier 2 — HLD Blogs (EM audience):&lt;/b&gt; &amp;quot;Fraud Detection at 50 SDEs: Kafka vs Iggy&amp;quot; | &amp;quot;Agentic AI Backbone Problem&amp;quot; | &amp;quot;Multi-Service Arch on a Budget&amp;quot;&lt;br&gt;&lt;b&gt;Tier 3 — Tedious Arch Podcast:&lt;/b&gt; GCC eng leaders talk real decisions. Iggy = solution, not pitch. 30–40 min, 2x/month&lt;br&gt;&lt;b&gt;Tier 4 — LLD Deep Dives:&lt;/b&gt; &amp;quot;Thread-Per-Core + io_uring Deep Dive&amp;quot; | &amp;quot;Benchmarking Guide: Reproducible Results&amp;quot; | &amp;quot;1M User Leaderboard in Rust&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="1320" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="arr12" value="" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="380" as="sourcePoint"/>
            <mxPoint x="700" y="395" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 2: Evaluation -->
        <mxCell id="s2" value="&lt;b&gt;STAGE 2: EVALUATION (POC-Enabling)&lt;/b&gt;&lt;br&gt;&lt;b&gt;Goal:&lt;/b&gt; Engineer/team comparing Iggy to their stack — unblocked for POC in &amp;lt;2 hours&lt;br&gt;&lt;br&gt;• &lt;b&gt;Template Library:&lt;/b&gt; iggy-microservice-template | iggy-realtime-dashboard-template | iggy-ai-agent-event-bus-template&lt;br&gt;• &lt;b&gt;Solution Engineering Guide:&lt;/b&gt; &amp;quot;How to evaluate Apache Iggy for your team in one sprint&amp;quot;&lt;br&gt;• &lt;b&gt;Discord Presence:&lt;/b&gt; First responder for IST-timezone questions on Apache Iggy Discord (300+ members)&lt;br&gt;• &lt;b&gt;POC Support Offer:&lt;/b&gt; Free 2-hour &amp;quot;Iggy Architecture Review&amp;quot; session — eng consultation, not sales" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="1320" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="arr23" value="" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="520" as="sourcePoint"/>
            <mxPoint x="700" y="535" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 3: Adoption -->
        <mxCell id="s3" value="&lt;b&gt;STAGE 3: ADOPTION (Pre-Sales + Solution Engineering)&lt;/b&gt;&lt;br&gt;&lt;b&gt;Goal:&lt;/b&gt; Convert POC interest to production deployment&lt;br&gt;&lt;br&gt;• &lt;b&gt;Discovery Call (30 min):&lt;/b&gt; Current stack, pain points, team size&lt;br&gt;• &lt;b&gt;Custom Benchmark Run:&lt;/b&gt; iggy-bench vs their Kafka/NATS config — results via transparent benchmark framework&lt;br&gt;• &lt;b&gt;Architecture Replacement Sketch:&lt;/b&gt; &amp;quot;Before Kafka → After Iggy&amp;quot; diagram for their specific topology&lt;br&gt;• &lt;b&gt;Reference Check:&lt;/b&gt; Connect with early production users (Neferdata, SolidHash, Hugin.io)&lt;br&gt;• &lt;b&gt;Target Unit Size: 50 SDEs&lt;/b&gt; — big enough for real decisions, small enough for 2–3 engineers to drive evaluation" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="1320" height="145" as="geometry"/>
        </mxCell>

        <mxCell id="arr34" value="" style="endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="685" as="sourcePoint"/>
            <mxPoint x="700" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Stage 4: Advocacy -->
        <mxCell id="s4" value="&lt;b&gt;STAGE 4: EXPANSION &amp;amp; ADVOCACY (Word-of-Mouth Flywheel)&lt;/b&gt;&lt;br&gt;&lt;b&gt;Goal:&lt;/b&gt; Each adoption creates social proof that recruits the next cohort&lt;br&gt;&lt;br&gt;• &lt;b&gt;Case Studies:&lt;/b&gt; Ask each adopter for a blog post → published on iggy.apache.org/blogs (BLR deployment story = high-signal credibility)&lt;br&gt;• &lt;b&gt;Private Network:&lt;/b&gt; &amp;quot;Iggy India Adopters&amp;quot; Discord channel — pre-qualifies next wave&lt;br&gt;• &lt;b&gt;Amplify Adopters:&lt;/b&gt; Nominate for speaking slots at Rust India Meetup + OSI 2026&lt;br&gt;• &lt;b&gt;Legitimize:&lt;/b&gt; Submit &amp;quot;Iggy India Community&amp;quot; page to official Apache Iggy docs" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=10;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="705" width="1320" height="130" as="geometry"/>
        </mxCell>

        <!-- Competitive Intel -->
        <mxCell id="ci-title" value="&lt;b&gt;COMPETITIVE INTELLIGENCE: HOW COMPETITORS DO DevRel&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="850" width="1200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="ci1" value="&lt;b&gt;Redpanda ($265M VC)&lt;/b&gt;&lt;br&gt;• Daily community monitoring (Slack, Reddit)&lt;br&gt;• Migration guides: NATS→Redpanda, Kafka→Redpanda&lt;br&gt;• &amp;quot;Streamfest&amp;quot; virtual event (ShareChat DE spoke 2025)&lt;br&gt;• Tutorial series for enterprise use cases&lt;br&gt;&lt;b&gt;Iggy's Counter:&lt;/b&gt; Own the orthogonal lane:&lt;br&gt;&amp;quot;not Kafka-compatible, because we don't need to be.&amp;quot;&lt;br&gt;Redpanda CAN'T write &amp;quot;Why We Chose Not To Be Kafka Compat&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="430" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="ci2" value="&lt;b&gt;NATS (Synadia)&lt;/b&gt;&lt;br&gt;• Corporate backing + pure community model&lt;br&gt;• Lightweight messaging brand&lt;br&gt;&lt;b&gt;Weakness:&lt;/b&gt; JetStream persistence = architectural&lt;br&gt;overlay, not native&lt;br&gt;&lt;br&gt;&lt;b&gt;Iggy's Counter:&lt;/b&gt; &amp;quot;NATS is messaging,&lt;br&gt;Iggy is streaming&amp;quot; — legitimate differentiation" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="880" width="430" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="ci3" value="&lt;b&gt;Atlassian Model (for Amul)&lt;/b&gt;&lt;br&gt;• Combine business goals + user needs&lt;br&gt;  into single content statement&lt;br&gt;• Community content quadrant:&lt;br&gt;  what to write, how to structure, distribute&lt;br&gt;• Gamification + advocacy programs&lt;br&gt;&lt;b&gt;Core Lesson:&lt;/b&gt; Community content works when&lt;br&gt;it builds &lt;b&gt;confidence&lt;/b&gt;, not just awareness.&lt;br&gt;Every piece: &amp;quot;Does this help an engineer make&lt;br&gt;a confident decision about Iggy?&amp;quot;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="880" width="420" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
