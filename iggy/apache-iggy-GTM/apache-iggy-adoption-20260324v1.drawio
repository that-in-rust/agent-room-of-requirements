                <mxCell id="r8c2" value="Apache 2.0" style="text;html=1;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" parent="1" vertex="1">
