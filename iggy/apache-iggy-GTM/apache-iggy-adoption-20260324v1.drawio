<mxfile host="app.diagrams.net" agent="cursor">
  <diagram id="page1-pyramid" name="Pyramid-Apex">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Apex: The Executive Answer -->
        <mxCell id="apex" value="&lt;b&gt;EXECUTIVE ANSWER&lt;/b&gt;&lt;br&gt;Apache Iggy is the only Rust-native persistent streaming platform&lt;br&gt;with thread-per-core io_uring, zero external dependencies, and&lt;br&gt;public reproducible benchmarks.&lt;br&gt;&lt;br&gt;GTM = Category Creation: Own &amp;quot;Sovereign Streaming&amp;quot; — not &amp;quot;beat Kafka&amp;quot;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=13;spacingTop=5;spacingBottom=5;arcSize=8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="40" width="1000" height="120" as="geometry"/>
        </mxCell>

        <!-- Three Supporting Pillars -->
        <mxCell id="pillar-title" value="&lt;b&gt;THREE SUPPORTING PILLARS (Why This Is True)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="175" width="1000" height="30" as="geometry"/>
        </mxCell>

        <!-- Pillar 1 -->
        <mxCell id="p1" value="&lt;b&gt;1. Technical Moat&lt;/b&gt;&lt;br&gt;• Thread-per-core + io_uring + shared-nothing&lt;br&gt;• v0.7.0: P9999 improved 57% vs v0.5.0&lt;br&gt;• 3,361 MB/s read throughput, P9999 &amp;lt; 4ms&lt;br&gt;• Multi-protocol: QUIC, TCP, WebSocket, HTTP&lt;br&gt;• Zero-copy deserialization, AES-256-GCM&lt;br&gt;• Native Rust SDK: 90k crates.io downloads" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="210" width="310" height="160" as="geometry"/>
        </mxCell>

        <!-- Pillar 2 -->
        <mxCell id="p2" value="&lt;b&gt;2. Honest Benchmark Commitment&lt;/b&gt;&lt;br&gt;• benchmarks.iggy.apache.org — public, reproducible&lt;br&gt;• iggy-bench in core repo (not marketing artifact)&lt;br&gt;• Community can upload, compare, reproduce results&lt;br&gt;• No cherry-picked hardware, no undisclosed configs&lt;br&gt;• Directly attacks Redpanda/Confluent credibility&lt;br&gt;• The only such dashboard in streaming" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="210" width="320" height="160" as="geometry"/>
        </mxCell>

        <!-- Pillar 3 -->
        <mxCell id="p3" value="&lt;b&gt;3. Apache Governance + Trust&lt;/b&gt;&lt;br&gt;• Apache Incubator (Feb 2025), 12.4k GitHub stars&lt;br&gt;• 30+ global contributors, 300+ Discord members&lt;br&gt;• Code cannot be re-licensed or commercially captured&lt;br&gt;• TLP graduation expected 1–2 years&lt;br&gt;• Apache 2.0 license (vs Redpanda BSL)&lt;br&gt;• Long-term dependency risk = near zero" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="210" width="330" height="160" as="geometry"/>
        </mxCell>

        <!-- Situation / Complication / Resolution Bar -->
        <mxCell id="scr-title" value="&lt;b&gt;MINTO PYRAMID: SITUATION → COMPLICATION → RESOLUTION&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="390" width="1000" height="30" as="geometry"/>
        </mxCell>

        <!-- Situation -->
        <mxCell id="sit" value="&lt;b&gt;SITUATION&lt;/b&gt;&lt;br&gt;&lt;br&gt;• MQ market: $15B (2025) → $45B (2033), 17% CAGR&lt;br&gt;• Kafka owns the middle; Redpanda ($265M VC) owns Kafka-compat&lt;br&gt;• NATS owns edge messaging (persistence bolted on)&lt;br&gt;• Developers = new buyers: 49% influence purchases, 58% own budgets&lt;br&gt;• DLG displacing enterprise procurement for infra tooling&lt;br&gt;• Kafka 4.0 breaking changes → migration anxiety&lt;br&gt;• AI/Agentic wave creating new streaming use cases, no incumbent" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="425" width="310" height="220" as="geometry"/>
        </mxCell>

        <!-- Complication -->
        <mxCell id="comp" value="&lt;b&gt;COMPLICATION&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Kafka JVM GC = unpredictable P9999 (15–25ms)&lt;br&gt;• Redpanda solves ops, NOT sovereignty — VC exit pressure&lt;br&gt;  (Snowflake acquisition talks ~$1.5B)&lt;br&gt;• NATS JetStream persistence = architectural overlay&lt;br&gt;• Nobody owns &amp;quot;Rust + Performance + Honesty&amp;quot; category&lt;br&gt;• Zero Rust-native persistent streaming platforms exist&lt;br&gt;• Benchmark manipulation endemic in streaming market" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="425" width="320" height="220" as="geometry"/>
        </mxCell>

        <!-- Resolution -->
        <mxCell id="res" value="&lt;b&gt;RESOLUTION&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Category Creation: &amp;quot;Sovereign Streaming&amp;quot;&lt;br&gt;  — not Kafka-compatible, because we don't need to be&lt;br&gt;• Win NEW projects, don't poach old ones&lt;br&gt;• Positioning: &amp;quot;The only honest choice for teams&lt;br&gt;  building from scratch where performance is non-negotiable&amp;quot;&lt;br&gt;• North Star: Every Rust engineer defaults to asking&lt;br&gt;  &amp;quot;Is Iggy the right tool?&amp;quot; before &amp;quot;Which Kafka flavor?&amp;quot;&lt;br&gt;• Timing: Kafka breaking changes + AI wave + Rust growth" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=11;spacingLeft=8;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="425" width="330" height="220" as="geometry"/>
        </mxCell>

        <!-- Bottom: Positioning Statement -->
        <mxCell id="pos" value="&lt;b&gt;POSITIONING STATEMENT (For All External Communication)&lt;/b&gt;&lt;br&gt;Apache Iggy is the message streaming platform for teams that refuse to compromise on performance,&lt;br&gt;transparency, or software freedom. Built natively in Rust with io_uring and thread-per-core architecture,&lt;br&gt;it delivers predictable sub-millisecond tail latencies with zero external dependencies — no JVM, no ZooKeeper,&lt;br&gt;no vendor lock-in. If you're building from scratch and performance is non-negotiable, Iggy is the only honest choice." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=12;spacingTop=8;spacingBottom=8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="665" width="1000" height="110" as="geometry"/>
        </mxCell>

        <!-- Anti-Portfolio -->
        <mxCell id="anti" value="&lt;b&gt;ANTI-PORTFOLIO (What to Avoid)&lt;/b&gt;  |  ❌ Kafka comparison marketing (positions Iggy as derivative)  |  ❌ Enterprise feature overreach (no multi-region HA promises)  |  ❌ Ecosystem dilution (3–5 world-class integrations, not 120+)  |  ❌ Premature enterprise sales motion" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#000000;fontSize=11;spacingTop=5;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="790" width="1000" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page2-segments" name="Segments-BTD">
    <mxGraphModel dx="1400" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1400">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Page Title -->
        <mxCell id="stitle" value="&lt;b&gt;USER SEGMENT × DIFFERENTIATION × STRATEGY MATRIX&lt;/b&gt;&lt;br&gt;(Shreyas Doshi BTD Framework Applied)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="150" y="15" width="1100" height="40" as="geometry"/>
        </mxCell>

        <!-- SEGMENT 1: Rust Greenfield -->
        <mxCell id="s1-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;container=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="650" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="s1-header" value="&lt;b&gt;SEGMENT 1: RUST-NATIVE GREENFIELD BUILDER&lt;/b&gt;&lt;br&gt;Individual engineers and small teams (2–15) building new Rust services&lt;br&gt;Example: Gaming backends, fintech APIs, IoT platforms, developer tools, OSS maintainers" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="650" height="60" as="geometry"/>
        </mxCell>

        <!-- Pain -->
        <mxCell id="s1-pain" value="&lt;b&gt;PAIN:&lt;/b&gt;&lt;br&gt;Every Rust dev building real-time systems asks &amp;quot;What messaging layer?&amp;quot;&lt;br&gt;All answers are wrong: Kafka = JVM client, NATS = Go-native,&lt;br&gt;RabbitMQ = Erlang-native. No Rust-idiomatic persistent streaming exists." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="140" width="310" height="80" as="geometry"/>
        </mxCell>

        <!-- BTD -->
        <mxCell id="s1-btd" value="&lt;b&gt;BTD ANALYSIS:&lt;/b&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#2d7d46;&amp;quot;&gt;Differentiating:&lt;/b&gt; Rust ergonomics, native SDK, single binary&lt;br&gt;&lt;b style=&amp;quot;color:#b85450;&amp;quot;&gt;At Table Stakes:&lt;/b&gt; Performance (expected by this segment)&lt;br&gt;&lt;b style=&amp;quot;color:#999;&amp;quot;&gt;Below Table Stakes:&lt;/b&gt; Enterprise (SAML, audit logs) — N/A" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="140" width="310" height="80" as="geometry"/>
        </mxCell>

        <!-- Strategy -->
        <mxCell id="s1-strat" value="&lt;b&gt;STRATEGY: Community-Led Seeding&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &amp;quot;Building Real-Time [X] in Pure Rust with Apache Iggy&amp;quot; tutorials&lt;br&gt;• Target: This Week in Rust, r/rust, crates.io discovery&lt;br&gt;• awesome-rust repo listing + ecosystem guide placement&lt;br&gt;• Discord + GitHub Discussions + Zulip presence&lt;br&gt;• Sponsor Rustconf, RustNL for live demos&lt;br&gt;&lt;br&gt;&lt;b&gt;Conversion Trigger:&lt;/b&gt; Engineer asks &amp;quot;what streaming platform?&amp;quot;&lt;br&gt;→ Iggy is the pre-loaded answer in Rust collective memory&lt;br&gt;&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; crates.io velocity, GitHub stars, Discord joins" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="230" width="630" height="210" as="geometry"/>
        </mxCell>

        <!-- SEGMENT 2: Performance Platform Teams -->
        <mxCell id="s2-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;container=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="650" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="s2-header" value="&lt;b&gt;SEGMENT 2: PERFORMANCE-OBSESSED PLATFORM TEAM&lt;/b&gt;&lt;br&gt;Senior platform engineers where latency = revenue&lt;br&gt;Example: Online gaming, HFT analytics, real-time fraud, leaderboards, sports betting" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="650" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s2-pain" value="&lt;b&gt;PAIN:&lt;/b&gt;&lt;br&gt;Kafka JVM GC = unpredictable P9999 spikes (&amp;gt;50ms under load).&lt;br&gt;Redpanda is Kafka-compatible — protocol overhead remains.&lt;br&gt;These engineers want hardware's theoretical maximum, not approximation." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="540" width="310" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s2-btd" value="&lt;b&gt;BTD ANALYSIS:&lt;/b&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#2d7d46;&amp;quot;&gt;Differentiating:&lt;/b&gt; Tail latency + hardware efficiency&lt;br&gt;&lt;b style=&amp;quot;color:#b85450;&amp;quot;&gt;At Table Stakes:&lt;/b&gt; Ops tooling (CLI, Web UI, OTEL)&lt;br&gt;&lt;b style=&amp;quot;color:#999;&amp;quot;&gt;Below Table Stakes:&lt;/b&gt; Kafka compat — they WANT greenfield" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="540" width="310" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s2-strat" value="&lt;b&gt;STRATEGY: Proof-Based Technical Content&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &amp;quot;Anatomy of a Sub-Millisecond Streaming Platform&amp;quot; — HN, lobste.rs&lt;br&gt;• benchmarks.iggy.apache.org is the KILLER asset — only public&lt;br&gt;  reproducible streaming benchmark dashboard in existence&lt;br&gt;• &amp;quot;Why We Made Our Benchmarks Public&amp;quot; — values-based HN post&lt;br&gt;• Invite community to submit hardware results&lt;br&gt;• LMAX Disruptor / Aeron / mechanical sympathy communities&lt;br&gt;&lt;br&gt;&lt;b&gt;Conversion Trigger:&lt;/b&gt; Platform engineer spends 20 min on benchmark&lt;br&gt;dashboard → trusts results (can reproduce) → files internal ticket&lt;br&gt;&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; Dashboard unique visitors, Show HN traction, inbound issues" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="630" width="630" height="210" as="geometry"/>
        </mxCell>

        <!-- SEGMENT 3: Edge Operators -->
        <mxCell id="s3-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;container=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="650" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="s3-header" value="&lt;b&gt;SEGMENT 3: EDGE &amp;amp; CONSTRAINED-ENVIRONMENT OPERATOR&lt;/b&gt;&lt;br&gt;Edge computing, IoT, robotics, embedded, air-gapped, resource-constrained&lt;br&gt;Example: NVIDIA Jetson, Raspberry Pi clusters, factory floor, robotics" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="650" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s3-pain" value="&lt;b&gt;PAIN:&lt;/b&gt;&lt;br&gt;Kafka/Pulsar = massively over-engineered for edge.&lt;br&gt;NATS/MQTT = sacrifice durability for simplicity.&lt;br&gt;No single-binary, low-footprint, genuinely persistent platform&lt;br&gt;with sub-ms latency exists for constrained deployments." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="940" width="310" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s3-btd" value="&lt;b&gt;BTD ANALYSIS:&lt;/b&gt;&lt;br&gt;&lt;b style=&amp;quot;color:#2d7d46;&amp;quot;&gt;Differentiating:&lt;/b&gt; Single binary + minimal footprint&lt;br&gt;&lt;b style=&amp;quot;color:#b85450;&amp;quot;&gt;At Table Stakes:&lt;/b&gt; QUIC (for edge = differentiator)&lt;br&gt;&lt;b style=&amp;quot;color:#999;&amp;quot;&gt;Below Table Stakes:&lt;/b&gt; Enterprise compliance — irrelevant" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="940" width="310" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s3-strat" value="&lt;b&gt;STRATEGY: Ecosystem Partnership&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &amp;quot;Replace Mosquitto + DB with Iggy on your Pi cluster&amp;quot;&lt;br&gt;• Target: ROS forums, IIOT/OT communities, Embedded Linux Conf&lt;br&gt;• Partner with K3s, Talos, Balena.io edge deployment tools&lt;br&gt;• QUIC protocol = uniquely suited for intermittent connectivity&lt;br&gt;• A few MBs RAM, minimal CPU — runs on Jetson &amp; Raspberry Pi&lt;br&gt;&lt;br&gt;&lt;b&gt;Conversion Trigger:&lt;/b&gt; Robotics engineer needs reliable telemetry&lt;br&gt;on-device, realizes Kafka is insane for a 4-CPU ARM device&lt;br&gt;&lt;br&gt;&lt;b&gt;Metric:&lt;/b&gt; Docker Hub pulls, Helm installs, &amp;quot;edge&amp;quot; Discord tags" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d6b656;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="1030" width="630" height="210" as="geometry"/>
        </mxCell>

        <!-- SEGMENT 4: AI/Agentic (Emerging) -->
        <mxCell id="s4-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;dashed=1;container=0;" vertex="1" parent="1">
          <mxGeometry x="720" y="70" width="640" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="s4-header" value="&lt;b&gt;SEGMENT 4: AI / AGENTIC INFRA (EMERGING — Nurture Only)&lt;/b&gt;&lt;br&gt;Multi-agent AI systems, LLM apps, autonomous workflows&lt;br&gt;58% of India GCCs investing in agentic AI" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="70" width="640" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s4-body" value="&lt;b&gt;PAIN:&lt;/b&gt; Multi-agent systems need reliable, low-latency coordination&lt;br&gt;with durability and replay. Most teams hack Redis pub-sub or Kafka —&lt;br&gt;neither designed for bursty, low-volume, high-sensitivity agent messaging.&lt;br&gt;&lt;br&gt;&lt;b&gt;DIFFERENTIATION:&lt;/b&gt; Native MCP Server — streaming infra that is&lt;br&gt;AI-agent-aware out of the box. Architectural, not a connector bolt-on.&lt;br&gt;&lt;br&gt;&lt;b&gt;PLAY:&lt;/b&gt; Publish thought leadership content to seed the narrative&lt;br&gt;before Redpanda ($265M) owns it. Not heavy GTM investment — nurture." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#9673a6;fontColor=#000000;fontSize=10;spacingLeft=6;spacingTop=4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="140" width="620" height="120" as="geometry"/>
        </mxCell>

        <!-- Competitive Positioning Table -->
        <mxCell id="comp-title" value="&lt;b&gt;COMPETITIVE POSITIONING SUMMARY&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;fontColor=#000000;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="720" y="290" width="640" height="30" as="geometry"/>
        </mxCell>

        <!-- Table Header -->
        <mxCell id="th1" value="&lt;b&gt;Dimension&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#333333;strokeColor=#333333;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="325" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="th2" value="&lt;b&gt;Apache Kafka&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#333333;strokeColor=#333333;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="325" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="th3" value="&lt;b&gt;Redpanda&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#333333;strokeColor=#333333;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="325" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="th4" value="&lt;b&gt;NATS/JetStream&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#333333;strokeColor=#333333;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="325" width="130" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="th5" value="&lt;b&gt;Apache Iggy&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#b85450;strokeColor=#b85450;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="325" width="150" height="25" as="geometry"/>
        </mxCell>

        <!-- Table Rows -->
        <mxCell id="r1c1" value="Language" style="text;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontColor=#000000;fontSize=9;" vertex="1" parent="1"><mxGeometry x="720" y="350" width="120" height="22" as="geometry"/></mxCell>
